ATTENDEE;CUTYPE=INDIVIDUAL;ROLE=REQ-PARTICIPANT;PARTSTAT=ACCEPTED;CN=vinits
 hahdeo@gmail.com;X-NUM-GUESTS=0:mailto:vinitshahdeo@gmail.com
